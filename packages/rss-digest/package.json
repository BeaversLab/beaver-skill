{
  "name": "@beaverslab/rss-digest",
  "version": "0.5.0",
  "description": "Reusable RSS digest CLI orchestration and digest engine.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/BeaversLab/beaver-skill/tree/main/skills/beaver-rss-digest",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeaversLab/beaver-skill.git",
    "directory": "packages/rss-digest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "rss-digest": "./dist/src/bin.js"
  },
  "exports": {
    "./cli": "./dist/src/cli.js",
    "./file-config": "./dist/src/file-config.js",
    "./config-types": "./dist/src/types.js",
    "./digest-core": "./dist/src/digest-core.js",
    "./prompts": "./dist/src/prompts.js",
    ".": "./dist/src/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "README.en.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/src/assets && cp src/assets/*.yaml dist/src/assets/",
    "cli": "node dist/src/bin.js",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/tests/*.js"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.0",
    "ai": "^5.0.0",
    "cheerio": "^1.1.2",
    "js-yaml": "^4.1.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.9.2"
  }
}
