{
  "name": "@beaverslab/beaver-skill",
  "version": "0.4.1",
  "private": true,
  "description": "AI-powered agent skills collection for image generation and Xiaohongshu infographics",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "agent-skills",
    "skills",
    "ai-agents",
    "claude-code",
    "cursor",
    "gemini-cli",
    "codex",
    "image-generation",
    "xiaohongshu",
    "xhs"
  ],
  "homepage": "https://github.com/BeaversLab/beaver-skill",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeaversLab/beaver-skill.git"
  },
  "license": "MIT",
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "format": "prettier --write \"packages/**/*.ts\" \"skills/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\" \"skills/**/*.ts\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "prettier": "^3.8.1"
  }
}
