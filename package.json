{
  "name": "@beaverslab/beaver-skill",
  "version": "0.6.4",
  "private": true,
  "description": "AI-powered agent skills collection for image generation and Xiaohongshu infographics",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    ".",
    "packages/*",
    "skills"
  ],
  "keywords": [
    "agent-skills",
    "skills",
    "ai-agents",
    "claude-code",
    "cursor",
    "gemini-cli",
    "codex",
    "image-generation",
    "xiaohongshu",
    "xhs"
  ],
  "homepage": "https://github.com/BeaversLab/beaver-skill",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeaversLab/beaver-skill.git"
  },
  "license": "MIT",
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "format": "prettier --write \"packages/**/*.ts\" \"packages/**/*.md\" \"skills/**/*.ts\" \"skills/**/*.md\" \"*.md\"",
    "format:check": "prettier --check \"packages/**/*.ts\" \"packages/**/*.md\" \"skills/**/*.ts\" \"skills/**/*.md\" \"*.md\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{ts,md}": "prettier --write"
  }
}
